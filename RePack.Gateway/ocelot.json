{
  "Routes": [

    {
      "DownstreamPathTemplate": "/api/usuario/login",
      "DownstreamScheme": "https",

      "DownstreamHostAndPorts": [
        {
          "Host": "repack-usuario.onrender.com",
          "Port": 443
        }
      ],

      "UpstreamPathTemplate": "/gateway/usuarios/login",
      "UpstreamHttpMethod": [ "POST" ],

      "SwaggerKey": "usuario"
    },

